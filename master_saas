Tenant Isolation Middleware
@Injectable()
export class TenantIsolationMiddleware implements NestMiddleware {
  use(req: Request, res: Response, next: NextFunction) {
    const orgIdFromJwt = req.user?.organizationId;
    const orgIdFromRoute = req.params?.organizationId;

    // Cross-tenant access = immediate 403
    if (orgIdFromRoute && orgIdFromRoute !== orgIdFromJwt) {
      throw new ForbiddenException('Cross-tenant access denied');
    }

    // Suspended/frozen orgs = 403
    if (req.org?.status !== 'active') {
      throw new ForbiddenException('Organization is not active');
    }

    next();
  }
}

