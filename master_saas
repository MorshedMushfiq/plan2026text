@Injectable()
export class AuditService {
  async log(dto: {
    organizationId?: string;
    userId?: string;
    eventType: string;
    description: string;
    severity?: 'info' | 'warning' | 'critical';
    metadata?: Record<string, unknown>;
    ipAddress?: string;
    userAgent?: string;
    correlationId?: string;
  }) {
