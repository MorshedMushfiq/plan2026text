@Injectable()
export class JobWorkerService {
  // Runs every 3 seconds
  @Cron('*/3 * * * * *')
  async processJobs() {
    // SELECT FOR UPDATE SKIP LOCKED — prevents double processing
    const job = await this.prisma.$queryRaw`
      SELECT * FROM async_jobs
      WHERE status = 'pending'
        AND next_retry_at <= NOW()
      ORDER BY priority ASC, created_at ASC
      LIMIT 1
      FOR UPDATE SKIP LOCKED
    `;

    if (!job) return;

    await this.prisma.asyncJob.update({
      where: { id: job.id },
      data: { status: 'processing', startedAt: new Date() }
    });

    try {
      await this.dispatch(job.jobType, job.payload);
      await this.prisma.asyncJob.update({
        where: { id: job.id },
        data: { status: 'completed', completedAt: new Date() }
      });
    } catch (error) {
      const nextRetry = new Date(Date.now() + Math.pow(2, job.retryCount) * 5000);
      await this.prisma.asyncJob.update({
        where: { id: job.id },
        data: {
          status: job.retryCount >= job.maxRetries ? 'dead_letter' : 'pending',
          retryCount: { increment: 1 },
          nextRetryAt: nextRetry,
          lastError: error.message,
        }
      });
    }
  }

  private async dispatch(jobType: string, payload: unknown) {
    const handlers: Record<string, (p: unknown) => Promise<void>> = {
      'send_email':    (p) => this.emailService.send(p),
      'generate_pdf':  (p) => this.pdfService.generate(p),
      'send_webhook':  (p) => this.webhookService.send(p),
      // Add your job types here
    };

    const handler = handlers[jobType];
    if (!handler) throw new Error(`Unknown job type: ${jobType}`);
    await handler(payload);
  }
}


