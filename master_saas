    const safeMetadata = this.sanitize(dto.metadata);

    return this.prisma.auditLog.create({
      data: {
        organizationId: dto.organizationId,
        userId: dto.userId,
        eventType: dto.eventType,
        description: dto.description,
        severity: dto.severity ?? 'info',
        metadata: safeMetadata,
        ipAddress: dto.ipAddress,
        userAgent: dto.userAgent,
        correlationId: dto.correlationId ?? randomUUID(),
      }
    });
  }

  private sanitize(metadata?: Record<string, unknown>) {
    if (!metadata) return undefined;
    const BLOCKED_KEYS = ['password', 'token', 'secret', 'key', 'card', 'cvv', 'ssn'];
    return Object.fromEntries(
      Object.entries(metadata).filter(([k]) =>
        !BLOCKED_KEYS.some(blocked => k.toLowerCase().includes(blocked))
      )
    );
  }
}


