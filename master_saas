// Runs every 5 seconds via @nestjs/schedule
@Cron('*/5 * * * * *')
async processOutbox() {
  const messages = await this.prisma.outboxMessage.findMany({
    where: { status: 'pending' },
    orderBy: { createdAt: 'asc' },
    take: 50,
  });

  for (const msg of messages) {
    try {
      await this.eventBus.publish(msg.eventType, msg.payload);
      await this.prisma.outboxMessage.update({
        where: { id: msg.id },
        data: { status: 'sent' }
      });
    } catch {
      await this.prisma.outboxMessage.update({
        where: { id: msg.id },
        data: {
          retryCount: { increment: 1 },
          lastAttempt: new Date(),
          status: msg.retryCount >= 5 ? 'dead_letter' : 'pending',
        }
      });
    }
  }
}


