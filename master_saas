app.module.ts — Middleware Registration
@Module({ imports: [...allModules] })
export class AppModule implements NestModule {
  configure(consumer: MiddlewareConsumer) {
    // HTTPS redirect (defence-in-depth behind Nginx)
    consumer.apply(HttpsRedirectMiddleware)
      .forRoutes({ path: '*path', method: RequestMethod.ALL });

    // Tenant isolation — block partner/suspended orgs from business APIs
    consumer.apply(RequireTenantMiddleware)
      .forRoutes(
        { path: 'journals/*path', method: RequestMethod.ALL },
        { path: 'invoices/*path', method: RequestMethod.ALL },
        // ... all business routes
      );
  }
}

