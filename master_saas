4. Backend Architecture (NestJS)
main.ts — Bootstrap Pattern
async function bootstrap(): Promise<void> {
  // 1. Validate secrets FIRST — fail fast before anything starts
  loadAndValidateSecrets();

  // 2. Load TLS options
  const tlsOptions = loadTlsOptions();

  // 3. Create app
  const app = await NestFactory.create(AppModule, tlsOptions ? { httpsOptions: tlsOptions } : {});

  // 4. Global prefix (exclude health checks)
  app.setGlobalPrefix('api', { exclude: ['health', 'health/live', 'health/ready'] });

  // 5. Swagger (dev only or behind auth in prod)
  const swaggerConfig = new DocumentBuilder()
    .setTitle('Your SaaS API')
    .addBearerAuth({ type: 'http', scheme: 'bearer', bearerFormat: 'JWT' }, 'jwt')
    .build();
  SwaggerModule.setup('api/docs', app, SwaggerModule.createDocument(app, swaggerConfig));

  // 6. Security headers
  app.use(helmet({ hsts: process.env.NODE_ENV === 'production' ? { maxAge: 31536000 } : false }));

  // 7. CORS
  app.enableCors({ origin: process.env.CORS_ORIGIN?.split(','), credentials: true });

  // 8. Global validation pipe
  app.useGlobalPipes(new ValidationPipe({
    transform: true,
    whitelist: true,
    forbidNonWhitelisted: true,
    transformOptions: { enableImplicitConversion: true },
  }));

  // 9. Global filters & interceptors
  app.useGlobalFilters(new HttpExceptionFilter());
  app.useGlobalInterceptors(new LoggingInterceptor(), new ResponseTransformInterceptor());

  await app.listen(Number(process.env.PORT ?? 3001));
}


