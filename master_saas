Permission Guard
@Injectable()
export class PermissionGuard implements CanActivate {
  canActivate(context: ExecutionContext): boolean {
    const required = this.reflector.get<string>('permission', context.getHandler());
    if (!required) return true;

    const { user } = context.switchToHttp().getRequest();
    const allowed = PERMISSIONS[required] ?? [];

    if (!allowed.includes(user.role)) {
      // Log the denied attempt
      this.auditService.log({
        eventType: 'permission_denied',
        severity: 'warning',
        metadata: { permission: required, role: user.role }
      });
      throw new ForbiddenException(`Permission denied: ${required}`);
    }

    return true;
  }
}

