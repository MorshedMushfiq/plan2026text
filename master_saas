@Injectable()
export class YourResourceService {
  constructor(
    private readonly prisma: PrismaService,
    private readonly audit: AuditService,
    private readonly notifications: NotificationsService,
  ) {}

  async findAll(organizationId: string, query: ListQueryDto) {
    const { page = 1, limit = 20 } = query;
    const [items, total] = await this.prisma.$transaction([
      this.prisma.yourResource.findMany({
        where: { organizationId },
        skip: (page - 1) * limit,
        take: limit,
        orderBy: { createdAt: 'desc' },
      }),
      this.prisma.yourResource.count({ where: { organizationId } }),
    ]);
    return { items, total, page, limit, totalPages: Math.ceil(total / limit) };
  }

  async findOne(organizationId: string, id: string) {
    const item = await this.prisma.yourResource.findFirst({
      where: { id, organizationId },  // ALWAYS include organizationId
    });
    if (!item) throw new NotFoundException('Resource not found');
    return item;
  }

  async create(organizationId: string, userId: string, dto: CreateDto) {
    const item = await this.prisma.yourResource.create({
      data: { ...dto, organizationId, createdBy: userId },
    });

    await this.audit.log({
      organizationId,
      userId,
      eventType: 'resource.created',
      description: `Created resource ${item.id}`,
      metadata: { resourceId: item.id },
    });

    return item;
  }

  async approve(organizationId: string, id: string, userId: string) {
    const item = await this.findOne(organizationId, id);

    if (item.status !== 'submitted') {
      throw new BadRequestException('Only submitted items can be approved');
    }

    const updated = await this.prisma.$transaction(async (tx) => {
      const result = await tx.yourResource.update({
        where: { id },
        data: { status: 'approved', approvedBy: userId, approvedAt: new Date() },
      });

      await tx.outboxMessage.create({
        data: {
          eventType: 'resource.approved',
          aggregateId: id,
          payload: { resourceId: id, organizationId, approvedBy: userId },
          status: 'pending',
        },
      });

      return result;
    });

    await this.audit.log({
      organizationId,
      userId,
      eventType: 'resource.approved',
      description: `Approved resource ${id}`,
    });

    return updated;
  }
}


